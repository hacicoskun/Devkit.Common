{
  "ConnectionStrings": {
    "Default": "Server=127.0.0.1;Port=5432;Database=devkit_common;Password=your_password;UserId=admin;Include Error Detail=true;SSL Mode=Disable;CommandTimeout=300;Timeout=300"
  },
  "Messaging": {
    "Provider": "rabbitmq",
    "Host": "127.0.0.1",
    "Username": "admin",
    "Password": "your_password",
    "RabbitMQ": {
      "Port": 5672,
      "VirtualHost": "/"
    },
    "Kafka": {
      "SecurityProtocol": "SaslSsl"
    },
    "DefaultRetry": {
      "RetryLimit": 5,
      "InitialIntervalSeconds": 10
    }
  },
  "Cache": {
    "Provider": "Hybrid",
    "Redis": {
      "ConnectionString": "127.0.0.1:6379,password=your_password",
      "DefaultExpirationSeconds": 3600
    },
    "Memory": {
      "DefaultExpirationSeconds": 600
    }
  },
  "Identity": {
    "Provider": "Keycloak",
    "EnableAuthApi": true,
    "EnableUserApi": true,
    "Keycloak": {
      "BaseUrl": "",
      "Realm": "",
      "ClientId": "",
      "ClientSecret": "",
      "VerifyTokenAudience": true
    }
  },
  /* "Identity": {
    "Provider": "AspNetIdentity",
    "EnableAuthApi": true,
    "EnableUserApi": true,
    "AspNetIdentity": {
      "JwtSecretKey": "",
      "JwtIssuer": "https://localhost:5100",
      "JwtAudience": "devkit-client",
      "AccessTokenExpirationMinutes": 1440
    }
  }, */,
  "Jobs": {
    "Provider": "Hangfire",
    "UseQueue": true,
    "Storage": {
      "Type": "PostgreSQL",
      "ConnectionString": "Server=127.0.0.1;Port=5432;Database=devkit_common;Password=your_password;UserId=admin;Include Error Detail=true;SSL Mode=Disable;CommandTimeout=300;Timeout=300"
    },
    "Schedules": [
      {
        "JobName": "DateTimeLoggerJob",
        "Cron": "*/1 * * * *"
      }
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "MassTransit": "Trace",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}