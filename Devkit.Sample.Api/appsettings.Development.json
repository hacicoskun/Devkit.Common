{
  "ConnectionStrings": {
    "Default": "Server=localhost;Port=5432;Database=db_name;Password=your_password;UserId=root;Include Error Detail=true;SSL Mode=Disable;CommandTimeout=300;Timeout=300"
  },
  "Messaging": {
    "Provider": "rabbitmq",
    "Host": "localhost",
    "Username": "",
    "Password": "",
    "RabbitMQ": {
      "Port": 5672,
      "VirtualHost": "/"
    },
    "Kafka": {
      "SecurityProtocol": "SaslSsl"
    },
    "DefaultRetry": {
      "RetryLimit": 5,
      "InitialIntervalSeconds": 10
    }
  },
  "Cache": {
    "Provider": "Hybrid",
    "Redis": {
      "ConnectionString": "localhost:6379,password=your_password",
      "DefaultExpirationSeconds": 3600
    },
    "Memory": {
      "DefaultExpirationSeconds": 600
    }
  },
  "Jobs": {
    "Provider": "Hangfire",
    "UseQueue": true,
    "Storage": {
      "Type": "PostgreSQL",
      "ConnectionString": "Server=localhost;Port=5432;Database=db_name;Password=your_password;UserId=root;Include Error Detail=true;SSL Mode=Disable;CommandTimeout=300;Timeout=300"
    },
    "Schedules": [
      {
        "JobName": "DateTimeLoggerJob",
        "Cron": "*/1 * * * *"
      }
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "MassTransit": "Trace",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}